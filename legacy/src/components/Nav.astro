---
const navItems = [
  { label: "docs", href: "/docs" },
  { label: "arena", href: "/arena" },
  { label: "github", href: "https://github.com/mahimailabs/voicegateway" },
  { label: "changelog", href: "/docs/changelog" },
];
---

<header class="vg-topbar">
  <a class="vg-wordmark" href="/" aria-label="VoiceGateway home">
    <img class="vg-mascot" src="/brand/goat.svg" alt="" width="32" height="32" />
    <span class="vg-name">VoiceGateway</span>
    <span class="vg-tag" aria-hidden="true">// SDK</span>
  </a>

  <nav class="vg-links" aria-label="Primary">
    {
      navItems.map((item, i) => (
        <>
          <a href={item.href}>{item.label}</a>
          {i < navItems.length - 1 ? <span class="vg-sep" aria-hidden="true">·</span> : null}
        </>
      ))
    }
  </nav>

  <a class="btn accent vg-cta" href="/docs/getting-started">try the SDK</a>
</header>

<style>
  .vg-topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--paper);
    border-bottom: 1.5px solid var(--ink);
    padding: 12px 22px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .vg-wordmark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
  }

  .vg-mascot {
    width: 32px;
    height: 32px;
    display: block;
    flex-shrink: 0;
  }

  .vg-name {
    font-family: var(--hand-title);
    font-weight: 700;
    font-size: 26px;
    letter-spacing: 0.5px;
    line-height: 1;
  }

  .vg-tag {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-left: 2px;
  }

  .vg-links {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin: 0 auto;
    font-family: var(--hand);
    font-size: 14px;
  }

  .vg-links a {
    color: var(--ink);
    text-decoration: none;
    display: inline-block;
    padding: 4px 10px;
    border: 1.5px solid transparent;
    border-radius: 10px 12px 9px 13px;
    transform: rotate(-0.3deg);
    transition: border-color 120ms ease, background-color 120ms ease;
  }

  .vg-links a:hover,
  .vg-links a:focus-visible {
    border-color: var(--ink);
    background: var(--paper-2);
  }

  .vg-sep {
    color: var(--ink-soft);
    font-family: var(--hand);
    font-size: 14px;
    user-select: none;
  }

  .vg-cta {
    flex-shrink: 0;
  }

  @media (max-width: 880px) {
    .vg-topbar {
      padding: 10px 16px;
      gap: 10px;
    }
    .vg-name {
      font-size: 22px;
    }
    .vg-mascot {
      width: 26px;
      height: 26px;
    }
    .vg-tag {
      display: none;
    }
    .vg-links {
      order: 3;
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
      font-size: 13px;
      gap: 2px;
      padding-top: 8px;
      border-top: 1.2px dashed var(--line-soft);
      margin: 0;
    }
    .vg-cta {
      margin-left: auto;
    }
  }
</style>
