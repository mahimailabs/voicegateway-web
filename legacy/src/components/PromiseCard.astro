---
interface Props {
  num: string;
  title: string;
  body: string;
}
const { num, title, body } = Astro.props;
---

<div class="box soft vg-promise">
  <div class="tiny-mono">{num}</div>
  <div class="h-hand vg-promise-title">{title}</div>
  <p class="p-hand sm vg-promise-body">{body}</p>
</div>

<style>
  .vg-promise {
    padding: 14px 16px 16px;
    transform: rotate(-0.2deg);
  }
  .vg-promise:nth-of-type(even) {
    transform: rotate(0.3deg);
  }
  .vg-promise-title {
    margin: 4px 0 2px;
  }
  .vg-promise-body {
    color: var(--ink-2);
  }
</style>
