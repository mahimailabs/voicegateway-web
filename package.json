{
  "name": "voicegateway-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "pnpm build && pnpm build:cf && opennextjs-cloudflare preview",
    "deploy": "pnpm build && pnpm build:cf && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "sync-docs": "tsx scripts/sync-docs.ts",
    "prebuild": "pnpm sync-docs || echo 'sync skipped'"
  },
  "dependencies": {
    "fumadocs-core": "16.8.10",
    "fumadocs-mdx": "15.0.3",
    "fumadocs-ui": "16.8.10",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.9",
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.90.0"
  }
}
