# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
.vercel

# open-next cloudflare bundle
.open-next/

# legacy astro build output
dist/
.astro/
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# env files
.env*

# typescript
*.tsbuildinfo
next-env.d.ts

# editor + agent scratch
.vscode
.claude
.agents
.brand
.playwright-mcp
.idea/

# content sync target (populated by pnpm sync-docs)
content/docs/*
!content/docs/meta.json
!content/docs/guides
!content/docs/guides/meta.json
!content/docs/index.mdx

# fumadocs generated
.source/
