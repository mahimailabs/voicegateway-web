{
	"compatibility_date": "2026-05-11",
	"compatibility_flags": [
		"global_fetch_strictly_public",
		"nodejs_compat"
	],
	"name": "voicegateway-web",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"build": {
		"command": "npm run build"
	},
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}