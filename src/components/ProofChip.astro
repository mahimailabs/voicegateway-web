---
interface Props {
  text: string;
  rotation?: number;
}
const { text, rotation = -0.5 } = Astro.props;
---

<span class="chip vg-proof" style={`--vg-proof-rot: ${rotation}deg;`}>{text}</span>

<style>
  .vg-proof {
    font-size: 15px;
    padding: 4px 14px;
    transform: rotate(var(--vg-proof-rot, -0.5deg));
    background: var(--paper);
  }
</style>
