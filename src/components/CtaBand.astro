<section class="vg-cta-band" aria-labelledby="vg-cta-h">
  <div class="vg-cta-inner box accent">
    <p id="vg-cta-h" class="h-hand vg-cta-line">
      Stop paying for cost transparency you cannot see.
    </p>
    <a class="btn solid vg-cta-btn" href="/docs">
      Read the docs <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .vg-cta-band {
    max-width: 1080px;
    margin: 56px auto 0;
    padding: 0 24px;
  }
  .vg-cta-inner {
    padding: 26px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    transform: rotate(-0.15deg);
  }
  .vg-cta-line {
    font-size: clamp(22px, 3vw, 30px);
    margin: 0;
    max-width: 640px;
    line-height: 1.05;
  }
  .vg-cta-btn {
    font-size: 16px;
    padding: 8px 18px;
    flex-shrink: 0;
  }
  @media (max-width: 720px) {
    .vg-cta-band {
      padding: 0 16px;
    }
    .vg-cta-inner {
      padding: 22px 20px;
    }
  }
</style>
